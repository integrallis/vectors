<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        Build-tool-only dependencies: these JARs are used at build time by the SpotBugs
        Gradle plugin and are NOT shipped in library artifacts.
    -->

    <!-- Log4j: transitive dependency of com.github.spotbugs:spotbugs (static analysis) -->
