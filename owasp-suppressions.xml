<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        Build-tool-only dependencies: these JARs are used at build time by Gradle plugins
        (SpotBugs, Sigstore) and are NOT shipped in library artifacts.
    -->

    <!-- gRPC: transitive dependency of dev.sigstore:sigstore-java (signing plugin) -->
    <suppress>
        <notes>gRPC is a transitive dependency of the Sigstore signing plugin (sigstoreClientClasspath).
            Not included in published library JARs.</notes>
        <cpe>cpe:2.3:a:grpc:grpc:*:*:*:*:*:*:*:*</cpe>
        <cve>CVE-2026-33186</cve>
    </suppress>

    <!-- Log4j: transitive dependency of com.github.spotbugs:spotbugs (static analysis) -->
