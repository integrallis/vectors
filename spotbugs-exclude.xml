<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- VectorizationProvider.getInstance() returns an immutable interface reference -->
    <Match>
        <Class name="com.integrallis.vectors.core.VectorizationProvider"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <!-- Storage module: segment()/slab() intentionally expose MemorySegment for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.storage.io.MappedSegmentInput"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.storage.io.MappedSegmentInputSupplier"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.storage.memory.SlabAllocator"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Quantization module: ArrayVectorDataset intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.quantization.ArrayVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Deterministic Random(seed) for reservoir sampling / rotation generation is intentional -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.quantization.ScalarQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.ProductQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.RandomRotation"/>
            <Class name="com.integrallis.vectors.quantization.GivensRotation"/>
            <Class name="com.integrallis.vectors.quantization.QuaternionRotation"/>
            <Class name="com.integrallis.vectors.hnsw.RandomLevelGenerator"/>
        </Or>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <!-- HNSW: SearchResult record exposes/stores arrays intentionally for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.SearchResult"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <!-- HNSW: InMemoryVectors intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.InMemoryVectors"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- HNSW: VectorStoreVectors.getVector returns shared buffer by design -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.VectorStoreVectors"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- HNSW: HnswGraphBuilder.build() returns internal graph intentionally -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.HnswGraphBuilder"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- HNSW: RandomAccessVectorDataset intentionally stores reference for zero-copy bridge -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.RandomAccessVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Vamana: SearchResult record exposes/stores arrays intentionally for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.SearchResult"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <!-- Vamana: InMemoryVectors intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.InMemoryVectors"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Vamana: VamanaGraphBuilder uses deterministic Random(seed) and returns internal graph -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.VamanaGraphBuilder"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
        </Or>
    </Match>
    <!-- Vamana: VamanaIndex.graph() returns internal graph for testing/inspection -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.VamanaIndex"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Vamana: RandomAccessVectorDataset intentionally stores reference for zero-copy bridge -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.RandomAccessVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- vectors-db: public records intentionally expose internal array references -->
    <Match>
        <Class name="com.integrallis.vectors.db.Document"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.SearchRequest"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.SearchResult"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- vectors-db: IndexSpi.SearchOutcome and FlatScanAdapter intentionally share
         array references for zero-copy between the backend and the facade. -->
    <Match>
        <Class name="com.integrallis.vectors.db.index.IndexSpi$SearchOutcome"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.index.FlatScanAdapter"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- vectors-db: StagingBuffer deliberately hands out its internal document list to the
         VectorCollectionImpl commit pipeline. Safety comes from the enclosing writer lock;
         exposing the list avoids an unnecessary copy of up to autoCommitThreshold documents
         on every commit. -->
    <Match>
        <Class name="com.integrallis.vectors.db.internal.StagingBuffer"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

</FindBugsFilter>
