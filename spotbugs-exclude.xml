<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- VectorizationProvider.getInstance() returns an immutable interface reference -->
    <Match>
        <Class name="com.integrallis.vectors.core.VectorizationProvider"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <!-- Storage module: segment()/slab() intentionally expose MemorySegment for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.storage.io.MappedSegmentInput"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.storage.io.MappedSegmentInputSupplier"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.storage.memory.SlabAllocator"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Quantization module: ArrayVectorDataset intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.quantization.ArrayVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Deterministic Random(seed) for reservoir sampling / rotation generation is intentional -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.quantization.ScalarQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.ProductQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.RandomRotation"/>
            <Class name="com.integrallis.vectors.quantization.GivensRotation"/>
            <Class name="com.integrallis.vectors.quantization.QuaternionRotation"/>
            <Class name="com.integrallis.vectors.hnsw.RandomLevelGenerator"/>
        </Or>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <!-- HNSW: SearchResult record exposes/stores arrays intentionally for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.SearchResult"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <!-- HNSW: InMemoryVectors intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.InMemoryVectors"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- HNSW: VectorStoreVectors.getVector returns shared buffer by design -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.VectorStoreVectors"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- HNSW: HnswGraphBuilder.build() returns internal graph intentionally -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.HnswGraphBuilder"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- HNSW: HnswIndex.graph() returns the internal graph reference for the persistence
         path (HnswGraphCodec.encode). Callers must not mutate it, enforced by javadoc. -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.HnswIndex"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- HNSW: RandomAccessVectorDataset intentionally stores reference for zero-copy bridge -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.RandomAccessVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- HNSW: FusedAdcGraph and FusedAdcNeighborList store arrays by reference for zero-copy ADC search -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.hnsw.FusedAdcGraph"/>
            <Class name="com.integrallis.vectors.hnsw.FusedAdcNeighborList"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <!-- HNSW: ConcurrentHnswGraphBuilder lock release paths — locks are released in finally
         blocks within the concurrent insert/snapshot methods; SpotBugs cannot track the
         lock-per-node scheme through the concurrent algorithm. -->
    <Match>
        <Class name="com.integrallis.vectors.hnsw.ConcurrentHnswGraphBuilder"/>
        <Bug pattern="UL_UNRELEASED_LOCK,UL_UNRELEASED_LOCK_EXCEPTION_PATH"/>
    </Match>
    <!-- Vamana: SearchResult record exposes/stores arrays intentionally for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.SearchResult"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <!-- Vamana: InMemoryVectors intentionally stores reference for zero-copy access -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.InMemoryVectors"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Vamana: VamanaGraphBuilder uses deterministic Random(seed) and returns internal graph -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.VamanaGraphBuilder"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
        </Or>
    </Match>
    <!-- Vamana: VamanaIndex.graph() returns internal graph for testing/inspection -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.VamanaIndex"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Vamana: RandomAccessVectorDataset intentionally stores reference for zero-copy bridge -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.RandomAccessVectorDataset"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- Vamana: ConcurrentVamanaGraphBuilder lock release paths — same pattern as HNSW. -->
    <Match>
        <Class name="com.integrallis.vectors.vamana.ConcurrentVamanaGraphBuilder"/>
        <Bug pattern="UL_UNRELEASED_LOCK,UL_UNRELEASED_LOCK_EXCEPTION_PATH"/>
    </Match>
    <!-- Quantization module: serialization accessors and public constructors intentionally
         expose/store internal array references for zero-copy codec round-trip. -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.quantization.RandomRotation"/>
            <Class name="com.integrallis.vectors.quantization.GivensRotation"/>
            <Class name="com.integrallis.vectors.quantization.QuaternionRotation"/>
            <Class name="com.integrallis.vectors.quantization.ProductQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.BinaryQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.RaBitQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.NVQuantizer"/>
            <Class name="com.integrallis.vectors.quantization.OptimizedProductQuantizer"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Quantization module: QuantizationPipeline.Builder.scalarBits is set by the builder
         but read via build() — SpotBugs UrF is a false positive for builder-pattern fields. -->
    <Match>
        <Class name="com.integrallis.vectors.quantization.QuantizationPipeline$Builder"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.quantization.ScalarQuantizedVectors"/>
            <Class name="com.integrallis.vectors.quantization.PQVectors"/>
            <Class name="com.integrallis.vectors.quantization.BinaryQuantizedVectors"/>
            <Class name="com.integrallis.vectors.quantization.RaBitQuantizedVectors"/>
            <Class name="com.integrallis.vectors.quantization.NVQuantizedVectors"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP2"/>
            <Bug pattern="EI_EXPOSE_REP"/>
        </Or>
    </Match>
    <!-- vectors-db: public records intentionally expose internal array references -->
    <Match>
        <Class name="com.integrallis.vectors.db.Document"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.SearchRequest"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.SearchResult"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- vectors-db: IndexSpi.SearchOutcome and FlatScanAdapter intentionally share
         array references for zero-copy between the backend and the facade. -->
    <Match>
        <Class name="com.integrallis.vectors.db.index.IndexSpi$SearchOutcome"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Class name="com.integrallis.vectors.db.index.FlatScanAdapter"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- vectors-db: MemorySegmentVectors.segment() intentionally exposes the whole-file
         MemorySegment for tight inner-loop scoring in MappedFlatScanAdapter. The segment is
         read-only and its lifetime is owned by a caller-provided Arena, so callers cannot
         corrupt state through it. Defensively copying would defeat the zero-copy design. -->
    <Match>
        <Class name="com.integrallis.vectors.db.storage.MemorySegmentVectors"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- vectors-bench: FvecsLoader returns raw float[][], int[][], byte[][] arrays
         for zero-copy benchmark setup. Defensive copies would defeat the purpose. -->
    <Match>
        <Class name="com.integrallis.vectors.bench.dataset.FvecsLoader"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS"/>
        </Or>
    </Match>
    <!-- vectors-bench: Hdf5Loader returns reshaped arrays directly from HDF5 file data. -->
    <Match>
        <Class name="com.integrallis.vectors.bench.dataset.Hdf5Loader"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS"/>
        </Or>
    </Match>
    <!-- vectors-bench: RecallUtil.bruteForceGroundTruth returns raw int[][] ground-truth
         arrays; callers own the result and may not copy it. -->
    <Match>
        <Class name="com.integrallis.vectors.bench.RecallUtil"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- vectors-core cluster package: KMeans reuses rng across k-means++ seeding and
         Lloyd iterations; SpotBugs misidentifies each call site as an independent use.
         CentroidIndex and BuoyIndex intentionally store/return centroid arrays by reference
         (zero-copy) — copying a K×D matrix on every route() call would defeat the purpose. -->
    <Match>
        <Class name="com.integrallis.vectors.core.cluster.KMeans"/>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.core.cluster.CentroidIndex"/>
            <Class name="com.integrallis.vectors.core.cluster.CentroidIndex$RouteResult"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP2"/>
            <Bug pattern="EI_EXPOSE_REP"/>
        </Or>
    </Match>

    <!-- vectors-db: VectorEvent records store/expose float[] vector by reference for
         zero-copy WAL encoding. Defensive copy would double allocation on every mutation. -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.db.event.VectorEvent$Add"/>
            <Class name="com.integrallis.vectors.db.event.VectorEvent$Upsert"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-storage: S3StorageBackend stores the caller-provided S3Client by reference.
         S3Client is an SDK interface and cannot be defensively copied; the constructor contract
         documents that the client is owned by this backend instance and closed on close(). -->
    <Match>
        <Class name="com.integrallis.vectors.storage.backend.S3StorageBackend"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-storage: LocalFileStorageBackend resolves keys relative to a non-root root
         directory, so Path.getParent() and Path.getFileName() are never null for any path
         produced by root.resolve(key). SpotBugs cannot verify this from the return types alone. -->
    <Match>
        <Class name="com.integrallis.vectors.storage.backend.LocalFileStorageBackend"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- vectors-ivf: TieredCluster holds a reference to the global vector array for zero-copy
         access during scan and T1 materialisation. Copying the entire N×D matrix into each
         TieredCluster would multiply memory consumption by K (number of clusters). -->
    <Match>
        <Class name="com.integrallis.vectors.ivf.TieredCluster"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-ivf: BuoyIndex, ClusterPartition, IvfIndex, IvfSearchRequest, and
         IvfSearchResult store/return array and List references intentionally (zero-copy
         routing and search). Defensive copies at K=1024, D=128 would add 512 KB to every
         route() call and defeat the <10 µs latency target. -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.ivf.BuoyIndex"/>
            <Class name="com.integrallis.vectors.ivf.ClusterPartition"/>
            <Class name="com.integrallis.vectors.ivf.IvfIndex"/>
            <Class name="com.integrallis.vectors.ivf.IvfSearchRequest"/>
            <Class name="com.integrallis.vectors.ivf.IvfSearchResult"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-db: SegmentExporter.export iterates over directory entries; Path.getFileName()
         is never null for paths returned by Files.list() (they always have at least one element).
         SpotBugs cannot prove this from the return type alone, so it flags a false positive. -->
    <Match>
        <Class name="com.integrallis.vectors.db.transfer.SegmentExporter"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- vectors-bench: JMH @State setUp() methods use Random seeded once per trial; SpotBugs
         misidentifies calls across multiple loops/methods as "used only once". Same for
         macro benchmark corpus generation (deterministic seed for reproducibility). -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.bench.DistanceKernelBenchmark"/>
            <Class name="com.integrallis.vectors.bench.QuantizerKernelBenchmark"/>
            <Class name="com.integrallis.vectors.bench.IndexBuildBenchmark"/>
            <Class name="com.integrallis.vectors.bench.AnnSearchBenchmark"/>
            <Class name="com.integrallis.vectors.bench.IvfSearchBenchmark"/>
            <Class name="com.integrallis.vectors.bench.VectorDbBenchmark"/>
            <Class name="com.integrallis.vectors.bench.BuildScalabilityBenchmark"/>
            <Class name="com.integrallis.vectors.bench.IvfPqSearchBenchmark"/>
            <Class name="com.integrallis.vectors.bench.IvfPqMmapSearchBenchmark"/>
            <Class name="com.integrallis.vectors.bench.IvfPqLargeScaleBenchmark"/>
            <Class name="com.integrallis.vectors.bench.PqTrainProbe"/>
            <Class name="com.integrallis.vectors.bench.HnswThreadScalingProbe"/>
        </Or>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>

    <!-- vectors-bench: BenchmarkResult.Builder stores Map references for builder-pattern
         convenience. Record compact constructor does Map.copyOf() for immutability. -->
    <Match>
        <Class name="com.integrallis.vectors.bench.report.BenchmarkResult$Builder"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-bench: DatasetDownloader.download() and BenchmarkReporter.csv/json create
         parent directories via Files.createDirectories() which never returns null for valid
         paths. SpotBugs cannot prove this statically. -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.bench.dataset.DatasetDownloader"/>
            <Class name="com.integrallis.vectors.bench.report.BenchmarkReporter"/>
        </Or>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- vectors-bench: JSON output uses literal \n for JSON formatting (not platform newlines).
         JSON spec requires LF, not CR+LF. SpotBugs FS_BAD_LOCALE warning is a false positive
         for structured data output. -->
    <Match>
        <Class name="com.integrallis.vectors.bench.report.BenchmarkReporter"/>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>

    <!-- vectors-distributed: LocalSearchRequest stores float[]/int[] by reference for zero-copy
         query routing — defensive copy at scatter-gather call rates would add significant GC
         pressure. The query vector is owned by the caller and must not be mutated after passing. -->
    <Match>
        <Class name="com.integrallis.vectors.distributed.LocalSearchRequest"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-distributed: DistributedVectorCollection$Builder stores a VectorCollection
         reference. VectorCollection is an interface and cannot be cloned; the lifecycle is
         owned by the caller and documented in the builder's javadoc. -->
    <Match>
        <Class name="com.integrallis.vectors.distributed.DistributedVectorCollection$Builder"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-db: QvCacheKey stores byte[] quantized query by reference for zero-copy
         cache key identity. The key is immutable-by-contract; copying the array on every
         cache lookup would defeat the per-query fast path. -->
    <Match>
        <Class name="com.integrallis.vectors.db.cache.QvCacheKey"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-db: VectorCollectionImpl.openGeneration intentionally catches Exception
         (not just IOException) so that arena.close() fires even on unchecked exceptions
         like ArithmeticException from Math.toIntExact. The broad catch is a resource-safety
         net, not a control-flow mechanism. -->
    <Match>
        <Class name="com.integrallis.vectors.db.VectorCollectionImpl"/>
        <Method name="openGeneration"/>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

    <!-- vectors-spring-boot-starter: JavaVectorsProperties uses standard Spring Boot @ConfigurationProperties
         getter/setter pattern. Properties are mutable POJO beans managed by the Spring container.
         EI_EXPOSE_REP/EI2 warnings are inherent to the Spring ConfigurationProperties design. -->
    <Match>
        <Class name="com.integrallis.vectors.spring.boot.JavaVectorsProperties"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-vcr-*: CassetteRecord subtypes, VCRContext, and wrapper classes intentionally
         share float[] embedding references and framework-specific model instances by reference
         (zero-copy recording path; wrapping must not clone the underlying model). -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.vcr.CassetteRecord$Embedding"/>
            <Class name="com.integrallis.vectors.vcr.CassetteRecord$BatchEmbedding"/>
            <Class name="com.integrallis.vectors.vcr.VCRContext"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.vcr.springai.VCRSpringAIEmbeddingModel"/>
            <Class name="com.integrallis.vectors.vcr.springai.VCRSpringAIChatModel"/>
            <Class name="com.integrallis.vectors.vcr.langchain4j.VCREmbeddingModel"/>
            <Class name="com.integrallis.vectors.vcr.langchain4j.VCRChatModel"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-db: IndexReplicas.commonSize is written once in build() under the writer lock
         and read in size() without synchronization. The stale-read window is benign. -->
    <Match>
        <Class name="com.integrallis.vectors.db.index.IndexReplicas"/>
        <Bug pattern="AT_STALE_THREAD_WRITE_OF_PRIMITIVE"/>
    </Match>
    <!-- vectors-db: IndexRefine intentionally stores the raw float[][] reference for zero-copy
         scoring. Defensive copy of the N×D matrix would multiply memory consumption. -->
    <Match>
        <Class name="com.integrallis.vectors.db.index.IndexRefine"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <!-- vectors-db: CuVs adapters write dimension/size once at init and read without sync.
         The stale-read window is benign (fields are effectively final after build()). -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.db.index.CuVsBruteForceAdapter"/>
            <Class name="com.integrallis.vectors.db.index.CuVsCagraAdapter"/>
        </Or>
        <Bug pattern="AT_STALE_THREAD_WRITE_OF_PRIMITIVE"/>
    </Match>

    <!-- vectors-server: ObjectMapperHolder intentionally returns the shared, thread-safe
         Jackson mapper by reference; constructing a copy per call would multiply server
         allocation by orders of magnitude. -->
    <Match>
        <Class name="com.integrallis.vectors.server.ObjectMapperHolder"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- vectors-server: DTO records expose float[] vectors by reference so Jackson can marshal
         without copying 384+ floats per request/hit. The wire boundary already returns fresh
         instances constructed from the live Document / SearchResult.Hit per request. -->
    <Match>
        <Or>
            <Class name="com.integrallis.vectors.server.dto.DocumentDto"/>
            <Class name="com.integrallis.vectors.server.dto.SearchQuery"/>
            <Class name="com.integrallis.vectors.server.dto.SearchHitDto"/>
            <Class name="com.integrallis.vectors.server.dto.UpsertDocumentsRequest"/>
        </Or>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

</FindBugsFilter>
