    <Match>
        <Class name="com.integrallis.vectors.bench.report.BenchmarkResult$Builder"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-bench: DatasetDownloader.download() and BenchmarkReporter.csv/json create
