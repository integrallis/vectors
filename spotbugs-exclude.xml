    <Match>
        <Class name="com.integrallis.vectors.distributed.DistributedVectorCollection$Builder"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-db: QvCacheKey stores byte[] quantized query by reference for zero-copy
