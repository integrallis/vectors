         documents that the client is owned by this backend instance and closed on close(). -->
    <Match>
        <Class name="com.integrallis.vectors.storage.backend.S3StorageBackend"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-storage: BackendWriteAheadLog stores the caller-provided StorageBackend by
         reference. StorageBackend is an SPI interface and cannot be defensively copied;
         the WAL piggybacks on the backend's lifecycle. -->
    <Match>
        <Class name="com.integrallis.vectors.storage.wal.BackendWriteAheadLog"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- vectors-storage: WalEntry record exposes the payload byte[] by reference for
         zero-copy producer/consumer handoff. The append/replay APIs document that the
         caller must not mutate the buffer once handed to the WAL. -->
    <Match>
        <Class name="com.integrallis.vectors.storage.wal.WriteAheadLog$WalEntry"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!-- vectors-storage: LocalFileStorageBackend resolves keys relative to a non-root root
