# =============================================================================
# vectors — example environment file
# =============================================================================
# Copy this file to `.env` at the repo root and fill in real values.  `.env` is
# gitignored (see .gitignore) and is loaded by the integration test suite via
# io.github.cdimascio:dotenv-java (testImplementation in vectors-storage).
#
# These values are *only* needed to run the optional cloud integration tests
# against a real S3-compatible object store. Every IT that reads them is
# annotated so that it skips silently when the corresponding variables are
# absent — leaving `.env` empty (or missing) is fine for normal development.
# =============================================================================


# -----------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible)
# -----------------------------------------------------------------------------
# Used by the R2 integration tests under vectors-storage. The endpoint URL is
# derived from VECTORS_R2_ACCOUNT_ID by default, in the form
# `https://<account-id>.r2.cloudflarestorage.com`. Set VECTORS_R2_ENDPOINT
# explicitly only if you need to override that default (e.g. jurisdiction-
# specific endpoints such as `.eu.r2.cloudflarestorage.com`).
#
# Region is ignored by R2 but the AWS SDK requires *some* value; `auto` is the
# Cloudflare-recommended placeholder.
#
# How to obtain these:
#   1. Cloudflare dashboard → R2 → Manage R2 API Tokens → "Create API Token".
#   2. Scope the token to the bucket below with Read & Write permissions.
#   3. Copy the Access Key ID and Secret Access Key shown once on token
#      creation (they are not retrievable later).

VECTORS_R2_ACCOUNT_ID=
VECTORS_R2_BUCKET=
VECTORS_R2_ACCESS_KEY=
VECTORS_R2_SECRET_KEY=
# VECTORS_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# VECTORS_R2_REGION=auto


# -----------------------------------------------------------------------------
# Cloudflare D1 (used by Studio's `--sidecart=D1` runtime mode)
# -----------------------------------------------------------------------------
# Used by `vectors-studio-web` (Studio) when `--sidecart=D1` is passed on the
# CLI. The token must have the `Account → D1 → Edit` permission for the
# database below. The `studio-r2-sidecart` demo reads these same keys, but
# from its own `demos/studio-r2-sidecart/.env` (see that file's example).
#
# How to obtain these:
#   1. `npx wrangler d1 create <db-name>` (or via the Cloudflare dashboard)
#      and copy the printed `database_id`.
#   2. Cloudflare dashboard → My Profile → API Tokens → "Create Token" →
#      "Custom token" → grant `Account / D1 / Edit` on the same account.
#
# VECTORS_CF_ACCOUNT_ID falls back to VECTORS_R2_ACCOUNT_ID when unset, so
# users with a single Cloudflare account only need to fill it in once above.

# VECTORS_CF_ACCOUNT_ID=
VECTORS_CF_API_TOKEN=
VECTORS_D1_DATABASE_ID=
